{
  "name": "convergence",
  "version": "0.0.0",
  "private": true,
  "description": "Generative music engine driven by Markov chain convergence",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./pitch": {
      "types": "./dist/pitch/index.d.ts",
      "import": "./dist/pitch/index.js"
    },
    "./mood": {
      "types": "./dist/mood/index.d.ts",
      "import": "./dist/mood/index.js"
    },
    "./conductor": {
      "types": "./dist/conductor/index.d.ts",
      "import": "./dist/conductor/index.js"
    },
    "./render/webaudio": {
      "types": "./dist/render/webaudio/index.d.ts",
      "import": "./dist/render/webaudio/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "demo": "vite"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
